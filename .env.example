# Example environment for the robotics digital twin.
#
# The app defaults to a fully self-contained SIMULATION and needs NO secrets,
# API keys, tokens, or external services to build or run. Copy to `.env` and
# adjust only if you opt into optional modes.
#
# NOTE: Vite inlines VITE_* at BUILD time. For the production (nginx) image,
# set these before `docker compose --profile prod up --build` (they are wired
# as build args). For dev they are passed to the Vite process.
#
# Never commit real secrets. `.env` is git/docker-ignored; this example is not.

# Operating mode: "simulation" (default) drives the on-screen digital twin only.
VITE_APP_MODE=simulation

# Optional ESP32 hardware transport. Default false → simulation only. Enabling
# this must never be required and must not break simulation if no device exists.
VITE_HARDWARE_ENABLED=false

# Optional agentic AI. Default false. The build must succeed with agent disabled
# and without any API keys or external services.
VITE_AGENT_ENABLED=false

# Optional backend/API base URL. Empty by default (no backend needed).
VITE_API_URL=
