{
  "name": "stylus-arm-digital-twin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-first software-in-the-loop validation platform for the stylus_arm URDF (Gate 1: Digital Twin).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "gl-matrix": "3.4.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "urdf-loader": "0.13.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "playwright": "^1.61.1",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
